# ─────────────────────────────────────────────────────────────────
# .env.example
# Salin file ini menjadi .env.local lalu isi nilainya
# BAB 5 — Environment Variables & Deployment
# ─────────────────────────────────────────────────────────────────

# Database — Neon PostgreSQL (https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — BAB 5: Autentikasi
AUTH_SECRET="generate-dengan-perintah: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Optional: GitHub OAuth Provider
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
